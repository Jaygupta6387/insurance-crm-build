# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# ─── Super Admin Database (READ-ONLY: used for company routing) ────────────────
# This is the already-built Super Admin database.
# The CRM backend only reads company metadata + DB config from here.
SUPER_ADMIN_DATABASE_URL="postgresql://jay@localhost:5432/new_super_admin_db?schema=public"

# ─── JWT Secrets ──────────────────────────────────────────────────────────────
# Use at least 32 random characters. Run: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=change_me_use_random_32_plus_chars_access
JWT_REFRESH_SECRET=change_me_use_random_32_plus_chars_refresh
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Password Hashing ─────────────────────────────────────────────────────────
BCRYPT_ROUNDS=12

# ─── Gmail SMTP ───────────────────────────────────────────────────────────────
MAIL_FROM_NAME=CRM Platform
MAIL_FROM_ADDRESS=noreply@yourplatform.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-gmail@gmail.com
# Use a Gmail App Password (not your account password)
SMTP_PASS=your-gmail-app-password

# ─── Frontend URLs (used in emails) ───────────────────────────────────────────
FRONTEND_RESET_PASSWORD_URL=http://localhost:5173

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=1000
AUTH_RATE_LIMIT_MAX=5

# ─── DB Credential Encryption (optional) ─────────────────────────────────────
# If the Super Admin system encrypts DB passwords in the companies table, set to true.
# The encryption key must match the one used by the Super Admin system.
ENCRYPT_DB_CREDENTIALS=false
DB_ENCRYPTION_KEY=32-byte-hex-key-here-must-match-super-admin

# ─── Swagger ──────────────────────────────────────────────────────────────────
SWAGGER_TITLE=CRM API
SWAGGER_VERSION=1.0.0
SWAGGER_DESCRIPTION=CRM Backend API - Authentication & Employee Management
