{
  "name": "crm-backend",
  "version": "1.0.0",
  "description": "CRM Backend — Multi-tenant Authentication & Employee Management",
  "main": "src/server.js",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "prisma:generate:superadmin": "prisma generate --schema=prisma/superadmin.prisma",
    "prisma:generate:company": "prisma generate --schema=prisma/company.prisma",
    "prisma:generate": "npm run prisma:generate:superadmin && npm run prisma:generate:company",
    "prisma:migrate:dev": "prisma migrate dev --schema=prisma/company.prisma",
    "prisma:migrate:deploy": "prisma migrate deploy --schema=prisma/company.prisma",
    "prisma:studio:superadmin": "prisma studio --schema=prisma/superadmin.prisma",
    "prisma:studio:company": "prisma studio --schema=prisma/company.prisma"
  },
  "dependencies": {
    "@prisma/client": "^5.13.0",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^6.9.13",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "winston": "^3.13.0",
    "zod": "^3.23.8",
    "prisma": "^5.13.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.3"
  }
}
